<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Keyboard Key Style -->
    <style name="KeyboardKey" parent="android:Widget.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/key_text_color</item>
        <item name="android:textSize">18sp</item>
        <item name="android:background">@drawable/key_background</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">0dp</item>
        <item name="android:stateListAnimator">@null</item> <!-- Disable default shadow elevation animation -->
    </style>

    <!-- Special Action Key Style (Shift, Del, etc.) -->
    <style name="KeyboardKey.Special">
        <item name="android:background">@drawable/key_background_special</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Accent Action Key Style (Enter) -->
    <style name="KeyboardKey.Accent">
        <item name="android:background">@drawable/key_background_accent</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
