{
  "name": "superword-desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"electron .\"",
    "package": "npm run build && electron-builder build --win --x64"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "docx": "^9.2.0",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.52.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.11"
  },
  "build": {
    "appId": "com.superword.app",
    "productName": "SuperWord",
    "copyright": "Copyright © 2026 SuperWord Team",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "dir"
    },
    "asar": true
  }
}
